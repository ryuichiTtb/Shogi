{
  "name": "shogi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm waveform:peaks && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:layout:card-shogi": "node scripts/card-shogi-layout-audit.mjs",
    "waveform:peaks": "tsx scripts/build-waveform-peaks.ts",
    "gen:fixture:legal-moves": "tsx scripts/gen-fixture-legal-moves.ts",
    "gen:fixture:evaluate": "tsx scripts/gen-fixture-evaluate.ts",
    "gen:fixture:strategy": "tsx scripts/gen-fixture-strategy.ts",
    "verify:strategy-fixture": "tsx scripts/verify-strategy-fixture.ts",
    "test:perf-bench": "RUN_PERF_BENCH=true vitest run src/lib/shogi/ai/__tests__/perf-bench.test.ts src/lib/shogi/ai/__tests__/perf-bench-spectator.test.ts",
    "test:perf-bench:human": "RUN_PERF_BENCH=true vitest run src/lib/shogi/ai/__tests__/perf-bench.test.ts",
    "test:perf-bench:spectator": "RUN_PERF_BENCH=true vitest run src/lib/shogi/ai/__tests__/perf-bench-spectator.test.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.3.1",
    "@fontsource/yuji-boku": "^5.2.8",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "audio-decode": "^3.10.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^25.0.1",
    "subset-font": "^2.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
